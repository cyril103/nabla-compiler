import collections.array

def keepLong(value: Long): Bool = {
    value > 2L
}

def addLong(left: Long, right: Long): Long = {
    left + right
}

def keepFloat(value: Float): Bool = {
    value > 1.0F
}

def addFloat(left: Float, right: Float): Float = {
    left + right
}

def keepDouble(value: Double): Bool = {
    value > 1.0
}

def addDouble(left: Double, right: Double): Double = {
    left + right
}

def keepBool(value: Bool): Bool = {
    value
}

def both(left: Bool, right: Bool): Bool = {
    left && right
}

def main(): Int = {
    val longs = Array.fill[Long](3, 4L)
    val keptLongs = longs.filter(keepLong)
    val longTotal = keptLongs.fold(1L, addLong)

    val floats = Array.fill[Float](2, 1.5F)
    val keptFloats = floats.filter(keepFloat)
    val floatTotal = keptFloats.fold(1.0F, addFloat)

    val doubles = Array.fill[Double](2, 2.5)
    val keptDoubles = doubles.filter(keepDouble)
    val doubleTotal = keptDoubles.fold(1.0, addDouble)

    val bools = Array.fill[Bool](3, true)
    val keptBools = bools.filter(keepBool)
    val boolTotal = keptBools.fold(true, both)

    if keptLongs.size() == 3 &&
       longTotal == 13L &&
       keptFloats.size() == 2 &&
       floatTotal > 3.9F &&
       keptDoubles.size() == 2 &&
       doubleTotal > 5.9 &&
       keptBools.countTrue() == 3 &&
       boolTotal {
        42
    } else {
        1
    }
}
