import collections.array

class Student(val name: String, val score: Int) {
    override def toString(): String = {
        name
    }
}

def firstSortedName[T](values: Array[T], lessThan: (T, T) => Bool): T = {
    values.sorted(lessThan).get(0)
}

def firstSortedInt(values: Array[Int], lessThan: (Int, Int) => Bool): Int = {
    values.sorted(lessThan).get(0)
}

def main(): Int = {
    val ada = new Student("Ada", 30)
    val bob = new Student("Bob", 10)
    val cy = new Student("Cy", 20)
    val students = Array.fill[Student](3, ada)
    students.set(1, bob)
    students.set(2, cy)

    val sorted = students.sorted((left, right) => left.score < right.score)
    val first = firstSortedName[Student](students, (left, right) => left.score < right.score)
    val ints = Array.fill[Int](3, 0)
    ints.set(0, 1)
    ints.set(1, 3)
    ints.set(2, 2)
    val firstIntDescending = firstSortedInt(ints, (left, right) => left > right)

    if students.get(0).name == "Ada" && sorted.get(0).name == "Bob" && sorted.get(2).name == "Ada" && first.name == "Bob" && firstIntDescending == 3 {
        42
    } else {
        1
    }
}
