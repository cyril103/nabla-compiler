import collections.set
import collections.array

class Student(name: String) {
    override def toString(): String = {
        name
    }
}

def makeNumbers(): Array[Int] = {
    Array(-1, 0, -1, 8, 16, 8, -9, 0)
}

def makeOtherNumbers(): Array[Int] = {
    Array(16, 32, -9, 32, 99)
}

def makeStudents(): Array[Student] = {
    val ada = new Student("ada")
    Array(ada, new Student("linus"), ada, new Student("grace"))
}

def main(): Int = {
    val values = makeNumbers()
    val fromArray = Set(values: _*)
    val roundTrip = fromArray.toArray()
    val reconstructed = Set.fromArray(roundTrip)
    val other = Set(makeOtherNumbers(): _*)
    val unioned = fromArray.union(other)
    val intersected = fromArray.intersect(other)
    val differenced = fromArray.difference(other)
    val added = fromArray.add(16).add(32).add(-1)
    val removed = added.remove(0).remove(99)
    val cleared = Set.empty[Int]()
    val students = Set(makeStudents(): _*)

    if values.toString() == "[-1, 0, -1, 8, 16, 8, -9, 0]" &&
       fromArray.toString() == "[-1, 0, 8, 16, -9]" &&
       fromArray.size() == 5 &&
       fromArray.contains(-1) &&
       fromArray.contains(0) &&
       fromArray.contains(16) &&
       fromArray.contains(-9) &&
       !fromArray.contains(7) &&
       roundTrip.size() == 5 &&
       roundTrip.get(0) == -1 &&
       roundTrip.get(1) == 0 &&
       roundTrip.get(2) == 8 &&
       roundTrip.get(3) == 16 &&
       roundTrip.get(4) == -9 &&
       reconstructed.toString() == "[-1, 0, 8, 16, -9]" &&
       other.toString() == "[16, 32, -9, 99]" &&
       unioned.toString() == "[-1, 0, 8, 16, -9, 32, 99]" &&
       intersected.toString() == "[16, -9]" &&
       differenced.toString() == "[-1, 0, 8]" &&
       added.toString() == "[-1, 0, 8, 16, -9, 32]" &&
       removed.toString() == "[-1, 8, 16, -9, 32]" &&
       cleared.toString() == "[]" &&
       cleared.size() == 0 &&
       cleared.isEmpty() &&
       students.toString() == "[ada, linus, grace]" &&
       students.size() == 3 &&
       !fromArray.isEmpty() {
        0
    } else {
        1
    }
}
