class Plain() {
}

class Person() {
    def toString(): String = {
        "person"
    }

    def hashCode(): Int = {
        99
    }
}

def main(): Int = {
    val plain = new Plain()
    val identity = plain.toString() == plain.toString() && plain.hashCode() == plain.hashCode()
    val override = new Person()
    if override.toString() == "person" && override.hashCode() == 99 {
        if identity {
            0
        } else {
            1
        }
    } else {
        1
    }
}
