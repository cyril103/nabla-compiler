def pick(value: Int): Int = {
    value + 1
}

def pick[T](value: T): T = {
    value
}

def applyInt(value: Int, f: (Int) => Int): Int = {
    f(value)
}

def applyString(value: String, f: (String) => String): String = {
    f(value)
}

def main(): Int = {
    val concrete = applyInt(41, pick)
    val generic = applyString("abc", pick)
    if concrete == 42 && generic.length() == 3 {
        42
    } else {
        1
    }
}
