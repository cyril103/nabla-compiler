function main() -> Int
  %0: Int = const 3
  store %0, @for.count.0
  jump for.cond.0
  label for.cond.0
  %1: Int = load @for.count.0
  %2: Int = const 0
  %3: Bool = > %1, %2
  branch_if_false %3, for.end.2
  label for.body.1
  %4: Int = const 1
  %5: Int = load @for.count.0
  %6: Int = const 1
  %7: Int = - %5, %6
  store %7, @for.count.0
  jump for.cond.0
  label for.end.2
  %8: Unit = const 0
  %9: Int = const 0
  return %9
