import collections.array
import core.option

class Student(nameValue: String, scoreValue: Int) {
    def name(): String = {
        nameValue
    }

    def score(): Int = {
        scoreValue
    }
}

def main(): Int = {
    val words = Array.fill[String](3, "hi")
    words.set(1, "hello")
    val longWords = words.filter(word => word.length() > 2)

    val ada = new Student("Ada", 21)
    val bob = new Student("Bob", 20)
    val students = Array.fill[Student](3, ada)
    students.set(1, bob)
    val topStudents = students.filter(student => student.score() > 20)

    val some = Option.some("yes")
    val none = Option.none("no")
    val options = Array.fill[Option[String]](3, some)
    options.set(2, none)
    val defined = options.filter(value => value.isDefined())

    if longWords.size() == 1 &&
       longWords.get(0).length() == 5 &&
       topStudents.size() == 2 &&
       topStudents.get(1).name().length() == 3 &&
       defined.size() == 2 &&
       defined.get(0).getOrElse("x").length() == 3 {
        42
    } else {
        1
    }
}
