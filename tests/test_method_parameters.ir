function Value.read(%this: Value) -> Int
  %0: Int = field %this, Value.number
  return %0

function Reader.read(%this: Reader, %value: Value) -> Int
  %0: Int = call_method Value.read(%value)
  return %0

function main() -> Int
  %0: Reader = new Reader()
  %1: Int = const 42
  %2: Value = new Value(%1)
  %3: Int = call_method Reader.read(%0, %2)
  return %3
