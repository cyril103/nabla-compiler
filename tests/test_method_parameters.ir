function Value.read(%this: Value) -> Int
  %0 = field %this, Value.number
  return %0

function Reader.read(%this: Reader, %value: Value) -> Int
  %0 = call_method Value.read(%value)
  return %0

function main() -> Int
  %0 = new Reader()
  %1 = const 42
  %2 = new Value(%1)
  %3 = call_method Reader.read(%0, %2)
  return %3
