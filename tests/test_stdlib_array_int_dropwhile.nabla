import collections.int_array

def main(): Int = {
    val xs = new ArrayInt(new IntArray(5))
    val index0 = 0
    xs.raw().set(index0, 0)
    xs.raw().set(index0 + 1, 0)
    xs.raw().set(index0 + 2, 1)
    xs.raw().set(index0 + 3, 0)
    xs.raw().set(index0 + 4, 2)

    val dropped = xs.dropWhile(value => value == 0)
    if dropped.size() == 3 && dropped.head() == 1 && dropped.last() == 2 {
        42
    } else {
        1
    }
}
