import collections.set

class Person(nameValue: String) {
    override def toString(): String = {
        nameValue
    }

    override def hashCode(): Int = {
        nameValue.length()
    }

    override def equals(other: Any): Bool = {
        nameValue == other.toString()
    }
}

class Badge extends Person(nameValue: String) {
}

def sameValue[T](left: T, right: T): Bool = {
    left == right
}

def render(value: Any): String = {
    value.toString()
}

def main(): Int = {
    val adaOne = new Badge("ada")
    val adaTwo = new Badge("ada")
    val bob = new Badge("bob")
    val people = Set[Person](adaOne, bob, adaTwo)
    if adaOne != bob &&
       adaOne == adaTwo &&
       sameValue[Person](adaOne, adaTwo) &&
       sameValue[Badge](adaOne, adaTwo) &&
       render(adaOne) == "ada" &&
       people.size() == 2 &&
       people.contains(adaTwo) &&
       people.toString() == "[ada, bob]" {
        42
    } else {
        1
    }
}
