import collections.array

def main(): Int = {
    val numbers = Array.range(3).map(value => value + 1)
    val words = Array.fill[String](3, "go")
    val left = numbers.mkString(",")
    val viaAlias = arrayMkString[Int](numbers, "-")
    val right = words.mkString("|")

    if left == "1,2,3" &&
       viaAlias == "1-2-3" &&
       right == "go|go|go" {
        42
    } else {
        1
    }
}
