import collections.array
import core.option

class Student(nameValue: String, scoreValue: Int) {
    def name(): String = {
        nameValue
    }

    def score(): Int = {
        scoreValue
    }
}

def main(): Int = {
    val words = Array.fill[String](2, "hi")
    words.set(1, "bye")
    val duplicated = Array("hi", "hi", "bye", "bye")

    val ada = new Student("Ada", 21)
    val bob = new Student("Bob", 20)
    val students = Array.fill[Student](2, ada)
    students.set(1, bob)
    val flattenedLabels = Array(
        Option.some[String](students.get(0).name()), Option.some[String]("top"),
        Option.some[String](students.get(1).name()), Option.none[String]()
    )

    if duplicated.size() == 4 &&
       duplicated.get(1).length() == 2 &&
       duplicated.get(2).length() == 3 &&
       flattenedLabels.size() == 4 &&
       flattenedLabels.get(1).getOrElse("x").length() == 3 &&
       flattenedLabels.get(3).isEmpty() {
        42
    } else {
        1
    }
}
