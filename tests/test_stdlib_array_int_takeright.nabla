import collections.int_array

def main(): Int = {
    val xs = new ArrayInt(new IntArray(5))
    val index0 = 0
    xs.raw().set(index0, 10)
    xs.raw().set(index0 + 1, 20)
    xs.raw().set(index0 + 2, 30)
    xs.raw().set(index0 + 3, 40)
    xs.raw().set(index0 + 4, 50)

    val right = xs.takeRight(2)
    if right.size() == 2 && right.get(0) == 40 && right.get(1) == 50 {
        42
    } else {
        1
    }
}
