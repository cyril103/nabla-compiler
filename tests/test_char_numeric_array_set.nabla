def main(): Int = {
    val ints = new IntArray(2)
    val longs = new LongArray(1)
    val floats = new FloatArray(1)
    val doubles = new DoubleArray(1)
    ints.set(0, 'A')
    ints.set(1, 'B' + 1)
    longs.set(0, 'C')
    floats.set(0, 'D')
    doubles.set(0, 'E')
    if ints.get(0) == 65 && ints.get(1) == 67 && longs.get(0) == 67L &&
       floats.get(0) == 68.0F && doubles.get(0) == 69.0 {
        0
    } else {
        1
    }
}
