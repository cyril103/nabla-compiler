import collections.array
import collections.set

class Person(nameValue: String) {
    override def toString(): String = {
        nameValue
    }
}

class Badge extends Person(nameValue: String) {
    override def hashCode(): Int = {
        7
    }
}

def hashOf[T](value: T): Int = {
    value.hashCode()
}

def main(): Int = {
    val ada = new Badge("ada")
    val bob = new Badge("bob")
    val values = new Array[Person](3)
    values.set(0, ada)
    values.set(1, bob)
    values.set(2, ada)
    val badges = Set.fromArray[Person](values)
    if ada.hashCode() == 7 &&
       bob.hashCode() == 7 &&
       hashOf[Person](ada) == 7 &&
       hashOf[Badge](ada) == 7 &&
       badges.size() == 2 &&
       badges.contains(ada) &&
       badges.contains(bob) &&
       badges.toString() == "[ada, bob]" {
        42
    } else {
        1
    }
}
