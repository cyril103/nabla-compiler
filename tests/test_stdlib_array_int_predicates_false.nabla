import collections.int_array

def main(): Int = {
    val xs = arrayIntRange(5)
    if xs.exists(value => value == 9) {
        1
    } else {
        if xs.forall(value => value < 3) {
            1
        } else {
            if xs.contains(9) {
                1
            } else {
                0
            }
        }
    }
}
