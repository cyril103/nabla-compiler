import collections.array

def main(): Int = {
    val empty = Array.range(0)
    val values = Array.range(3)
    if empty.size() == 0 && empty.isEmpty() && !empty.nonEmpty() {
        if values.size() == 3 && !values.isEmpty() && values.nonEmpty() {
            42
        } else {
            1
        }
    } else {
        2
    }
}
