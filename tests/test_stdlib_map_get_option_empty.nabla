import collections.map

def main(): Int = {
    val scores = Map("alice" -> 10, "bob" -> 20)
    val found = scores.getOption("alice")
    val missing = scores.getOption("carol")

    if !found.isDefined() {
        1
    } else if found.getOrElse(0) != 10 {
        2
    } else if !missing.isEmpty() {
        3
    } else if missing.getOrElse(42) != 42 {
        4
    } else if scores.getOption(0, "bob").getOrElse(0) != 20 {
        5
    } else {
        0
    }
}
