function TransformBox.transform(%this: TransformBox, %f: Fn(T)->T) -> T
  %0: T = field %this, TransformBox.value
  %1: T = indirect_call %f, %0
  return %1

function main() -> Int
  %0: Int = const 41
  %1: TransformBox[Int] = new TransformBox[Int](%0)
  store %1, @box#1
  %2: TransformBox[Int] = load @box#1
  %3: Closure = closure_ref lambda.0
  %4: Int = call_method TransformBox[Int].transform(%2, %3)
  return %4

function lambda.0(%value: Int) -> Int
  %0: Int = const 1
  %1: Int = + %value, %0
  return %1

function TransformBox[Int].transform(%this: TransformBox[Int], %f: Fn(Int)->Int) -> Int
  %0: Int = field %this, TransformBox[Int].value
  %1: Int = indirect_call %f, %0
  return %1
