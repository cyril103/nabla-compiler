function main() -> Int
  %0: Int = const 3
  %1: IntArray = new_int_array %0
  store %1, @xs#0
  %2: IntArray = load @xs#0
  %3: Int = const 10
  %4: Int = const 0
  %5: Unit = int_array_set %2, %4, %3
  %6: IntArray = load @xs#0
  %7: Int = const 20
  %8: Int = const 1
  %9: Unit = int_array_set %6, %8, %7
  %10: IntArray = load @xs#0
  %11: Int = const 12
  %12: Int = const 2
  %13: Unit = int_array_set %10, %12, %11
  %14: IntArray = load @xs#0
  %15: Int = const 0
  %16: Int = int_array_get %14, %15
  %17: IntArray = load @xs#0
  %18: Int = const 1
  %19: Int = int_array_get %17, %18
  %20: Int = + %16, %19
  %21: IntArray = load @xs#0
  %22: Int = const 2
  %23: Int = int_array_get %21, %22
  %24: Int = + %20, %23
  %25: IntArray = load @xs#0
  %26: Int = int_array_length %25
