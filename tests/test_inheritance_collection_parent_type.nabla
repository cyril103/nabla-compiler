import collections.set

class Person(nameValue: String) {
    def name(): String = {
        nameValue
    }

    override def toString(): String = {
        nameValue
    }
}

class Student extends Person() {
    override def toString(): String = {
        nameValue + " student"
    }
}

class Instructor extends Person() {
    override def toString(): String = {
        nameValue + " instructor"
    }
}

class Volunteer extends Person() {
    override def toString(): String = {
        nameValue + " volunteer"
    }
}

def main(): Int = {
    val ada = new Student("ada")
    val bob = new Instructor("bob")
    val cy = new Volunteer("cy")
    val unique = Set[Person](ada, bob, cy, ada)
    if unique.size() == 3 &&
       unique.contains(ada) &&
       unique.contains(bob) &&
       unique.contains(cy) &&
       unique.toString() == "[ada student, bob instructor, cy volunteer]" {
        42
    } else {
        1
    }
}
