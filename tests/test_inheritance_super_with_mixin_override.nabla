class Left() {
    def value(): Int = {
        10
    }
}

class Right() {
    def value(): Int = {
        20
    }
}

class Child extends Left with Right() {
    def value(): Int = {
        30
    }

    def inheritedFromLeft(): Int = {
        super.value()
    }
}

def main(): Int = {
    val child = new Child()
    child.value() + child.inheritedFromLeft()
}
