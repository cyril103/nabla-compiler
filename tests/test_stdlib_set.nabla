import collections.set
import collections.object_array

class Student(name: String) {
    def toString(): String = {
        name
    }
}

class ConstantHash(name: String, hashValue: Int) {
    def hashCode(): Int = {
        hashValue
    }

    def toString(): String = {
        name
    }
}

def sameValue[T](left: T, right: T): Bool = {
    left == right
}

def main(): Int = {
    val base = setEmpty[Int]()
    val rawNumbers = new ObjectArray[Int](4)
    rawNumbers.set(0, 1)
    rawNumbers.set(1, 3)
    rawNumbers.set(2, 1)
    rawNumbers.set(3, 2)
    val fromArray = setFromArray[Int](new ArrayObject[Int](rawNumbers))
    val fromArrayEmpty = setFromArray[Int](new ArrayObject[Int](new ObjectArray[Int](0)))
    val numbers = base.add(3).add(1).add(3).add(2)
    val otherNumbers = base.add(2).add(4).add(1)
    val removedThree = numbers.remove(3)
    val unchanged = numbers.remove(99)
    val unionedNumbers = numbers.union(otherNumbers)
    val intersectedNumbers = numbers.intersect(otherNumbers)
    val differenceNumbers = numbers.difference(otherNumbers)
    val unionedWithEmpty = numbers.union(base)
    val emptyDifference = base.difference(numbers)
    val differenceFromEmpty = numbers.difference(base)

    val alice = new Student("alice")
    val bob = new Student("bob")
    val students = setEmpty[Student]().add(alice).add(bob).add(alice)
    val studentSource = new ObjectArray[Student](4)
    studentSource.set(0, alice)
    studentSource.set(1, bob)
    studentSource.set(2, alice)
    studentSource.set(3, new Student("carol"))
    val studentsFromArray = setFromArray[Student](new ArrayObject[Student](studentSource))
    val others = setEmpty[Student]().add(bob).add(alice)
    val studentsUnion = students.union(others)
    val studentsIntersect = students.intersect(others)
    val studentsDifference = students.difference(others)
    val first = new ConstantHash("first", 3)
    val second = new ConstantHash("second", 3)
    val third = new ConstantHash("third", 3)
    val collisionSet = setEmpty[ConstantHash]()
        .add(first)
        .add(second)
        .add(first)
        .add(third)
    val collisionOther = setEmpty[ConstantHash]()
        .add(second)
        .add(new ConstantHash("fourth", 3))
    val collisionUnion = collisionSet.union(collisionOther)
    val collisionIntersect = collisionSet.intersect(collisionOther)
    val collisionDifference = collisionSet.difference(collisionOther)
    val collisionSource = new ObjectArray[ConstantHash](4)
    collisionSource.set(0, first)
    collisionSource.set(1, second)
    collisionSource.set(2, first)
    collisionSource.set(3, new ConstantHash("third", 3))
    val collisionFromArray = setFromArray[ConstantHash](new ArrayObject[ConstantHash](collisionSource))
    val collisionProbe = new ConstantHash("probe", 3)

    if numbers.size() == 3 &&
       fromArray.toString() == "[1, 3, 2]" &&
       fromArray.size() == 3 &&
       rawNumbers.length() == 4 &&
       rawNumbers.get(0) == 1 &&
       rawNumbers.get(1) == 3 &&
       rawNumbers.get(2) == 1 &&
       rawNumbers.get(3) == 2 &&
    studentSource.get(0).toString() == "alice" &&
    studentSource.get(1).toString() == "bob" &&
    studentSource.get(2).toString() == "alice" &&
       fromArrayEmpty.toString() == "[]" &&
       numbers.contains(1) &&
       !numbers.contains(4) &&
       numbers.toString() == "[3, 1, 2]" &&
       removedThree.size() == 2 &&
       removedThree.toString() == "[1, 2]" &&
       unchanged.size() == 3 &&
       unionedNumbers.toString() == "[3, 1, 2, 4]" &&
       intersectedNumbers.toString() == "[1, 2]" &&
       differenceNumbers.toString() == "[3]" &&
       unionedWithEmpty.toString() == "[3, 1, 2]" &&
       emptyDifference.toString() == "[]" &&
       differenceFromEmpty.toString() == "[3, 1, 2]" &&
       numbers.toString() == "[3, 1, 2]" &&
       students.size() == 2 &&
       students.toArray().size() == 2 &&
       !students.toArray().isEmpty() &&
       sameValue(3, 3) &&
       !sameValue(3, 4) &&
        studentsUnion.toString() == "[alice, bob]" &&
        studentsIntersect.toString() == "[alice, bob]" &&
        studentsDifference.toString() == "[]" &&
        studentsFromArray.toString() == "[alice, bob, carol]" &&
        studentsFromArray.size() == 3 &&
        students.contains(alice) &&
        sameValue(alice, students.toArray().get(0)) &&
        !collisionSet.contains(collisionProbe) &&
        collisionSet.toString() == "[first, second, third]" &&
        collisionUnion.toString() == "[first, second, third, fourth]" &&
        collisionIntersect.toString() == "[second]" &&
        collisionDifference.toString() == "[first, third]" &&
        collisionFromArray.toString() == "[first, second, third]" &&
        collisionFromArray.size() == 3 {
        0
    } else {
        1
    }
}
