class Runner() {
    def run[T](value: T, fixed: Int, transform: (T) => Int): Int = {
        transform(value)
    }

    def run[U](value: Int, fixed: U, transform: (U) => Int): Int = {
        transform(fixed)
    }
}

def main(): Int = {
    val runner = new Runner()
    runner.run(41, 7, value => {
        value + 1
    })
}
