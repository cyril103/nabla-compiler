class Parent() {
    def tag[T](value: T): String = {
        "parent:" + value.toString()
    }
}

class Child extends Parent() {
    override def tag[U](value: U): String = {
        "child:" + value.toString()
    }
}

def render(parent: Parent): String = {
    parent.tag[Int](42)
}

def main(): Int = {
    val child = new Child()
    if render(child) == "child:42" {
        42
    } else {
        1
    }
}
