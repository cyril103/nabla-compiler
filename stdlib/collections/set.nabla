def setFromArrayBool(values: ArrayBool): Set[Bool] = {
    val raw = new ObjectArray[Bool](values.size())
    var index = 0
    while index < values.size() {
        raw.set(index, values.get(index))
        index = index + 1
    }
    setFromArray[Bool](new ArrayObject[Bool](raw))
}

def setEmpty[T](): Set[T] = {
    new Set[T](new ArrayObject[T](new ObjectArray[T](0)))
}

/// Factory experimentale pour la famille Set.
/// @signature class SetFactory extends IterableFactory[Set]
/// @status Experimental
class SetFactory() with IterableFactory[Set] {
    /// Cree un Set[A] vide.
    /// @signature def empty[A](): Set[A]
    /// @status Experimental
    override def empty[A](): Set[A] = {
        setEmpty[A]()
    }

    /// Cree un builder pour produire un Set[A].
    /// @signature def newBuilder[A](): Builder[A, Set[A]]
    /// @status Experimental
    override def newBuilder[A](): Builder[A, Set[A]] = {
        new SetBuilder[A](setEmpty[A]())
    }
}

/// Builder experimental pour produire un Set[A].
/// @signature class SetBuilder[A] extends Builder[A, Set[A]]
/// @status Experimental
///
/// Le builder applique la semantique d'ensemble de Set.add: les doublons sont
/// dedupliques dans le resultat.
class SetBuilder[A](var values: Set[A]) with Builder[A, Set[A]] {
    /// Ajoute value au resultat logique.
    /// @signature def add(value: A): Unit
    /// @status Experimental
    override def add(value: A): Unit = {
        values = values.add(value)
        while false {
            0
        }
    }

    /// Retourne l'ensemble construit.
    /// @signature def result(): Set[A]
    /// @status Experimental
    override def result(): Set[A] = {
        values
    }
}

object Set {
    /// Cree un ensemble depuis les elements donnes.
    /// @signature def Set.apply[T](values: T*): Set[T]
    /// @status Recommandee
    def apply[T](values: T*): Set[T] = {
        Set.fromArray[T](values)
    }

    /// Cree un ensemble vide.
    /// @signature def Set.empty[T](): Set[T]
    /// @status Recommandee
    def empty[T](): Set[T] = {
        setEmpty[T]()
    }

    /// Retourne la factory experimentale de Set.
    /// @signature def Set.factory(): IterableFactory[Set]
    /// @status Experimental
    def factory(): IterableFactory[Set] = {
        new SetFactory()
    }

    /// Cree un builder experimental de Set[A].
    /// @signature def Set.newBuilder[A](): Builder[A, Set[A]]
    /// @status Experimental
    def newBuilder[A](): Builder[A, Set[A]] = {
        new SetBuilder[A](Set.empty[A]())
    }

    /// Deduplique un tableau en ensemble.
    /// @signature def Set.fromArray[T](values: Array[T]): Set[T]
    /// @status Recommandee
    ///
    /// Le compilateur accepte les facades Array[T] usuelles et choisit la
    /// representation adaptee. Le code utilisateur n'a pas a nommer les
    /// tableaux bas niveau pour construire un Set.
    def fromArray[T](values: ArrayObject[T]): Set[T] = {
        setFromArray[T](values)
    }
}

/// Ensemble immutable.
/// @signature class Set[T]
/// @status Recommandee
///
/// Les operations comme add, remove, union, intersect et difference
/// retournent un nouvel ensemble. L'instance d'origine n'est pas modifiee.
/// L'egalite repose sur == et l'index interne utilise hashCode(), ce qui permet
/// aux overrides utilisateur de participer a la deduplication.
class Set[T](values: ArrayObject[T]) with Sized with Iterable[T] {
    override def size(): Int = {
        values.size()
    }

    override def isEmpty(): Bool = {
        values.isEmpty()
    }

    override def nonEmpty(): Bool = {
        values.nonEmpty()
    }

    /// Indique si l'ensemble contient la valeur donnee.
    /// @signature def contains(value: T): Bool
    /// @status Recommandee
    def contains(value: T): Bool = {
        setContains[T](values, value)
    }

    /// Retourne un nouvel ensemble contenant value.
    /// @signature def add(value: T): Set[T]
    /// @status Recommandee
    def add(value: T): Set[T] = {
        if setContains[T](values, value) {
            this
        } else {
            new Set[T](setAppend[T](values, value))
        }
    }

    /// Retourne un nouvel ensemble sans value.
    /// @signature def remove(value: T): Set[T]
    /// @status Recommandee
    def remove(value: T): Set[T] = {
        new Set[T](setWithout[T](values, value))
    }

    /// Retourne l'union de deux ensembles.
    /// @signature def union(other: Set[T]): Set[T]
    /// @status Recommandee
    def union(other: Set[T]): Set[T] = {
        new Set[T](setUnion[T](values, other.toArray()))
    }

    /// Retourne l'intersection de deux ensembles.
    /// @signature def intersect(other: Set[T]): Set[T]
    /// @status Recommandee
    def intersect(other: Set[T]): Set[T] = {
        new Set[T](setIntersect[T](values, other.toArray()))
    }

    /// Retourne les elements de this absents de other.
    /// @signature def difference(other: Set[T]): Set[T]
    /// @status Recommandee
    def difference(other: Set[T]): Set[T] = {
        new Set[T](setDifference[T](values, other.toArray()))
    }

    /// Retourne un ensemble vide du meme type d'elements.
    /// @signature def clear(): Set[T]
    /// @status Recommandee
    def clear(): Set[T] = {
        setEmpty[T]()
    }

    /// Retourne les elements sous forme de tableau.
    /// @signature def toArray(): Array[T]
    /// @status Recommandee
    ///
    /// La representation visible actuelle est ArrayObject[T]. Manipuler le
    /// resultat via les operations communes et preferer Array[T] pour les
    /// nouvelles constructions applicatives.
    def toArray(): ArrayObject[T] = {
        values
    }

    /// Applique une fonction a chaque element.
    /// @signature def foreach(f: (T) => Unit): Unit
    /// @status Recommandee
    override def foreach(f: (T) => Unit): Unit = {
        values.foreach(f)
    }

    /// Cree un iterateur sur les elements de l'ensemble.
    /// @signature def iterator(): Iterator[T]
    /// @status Recommandee
    override def iterator(): Iterator[T] = {
        values.iterator()
    }

    /// Joint les elements avec un separateur.
    /// @signature def mkString(separator: String): String
    /// @status Recommandee
    def mkString(separator: String): String = {
        values.mkString(separator)
    }

    /// Retourne la representation sous forme de chaine de l'ensemble.
    /// @signature def toString(): String
    /// @status Recommandee
    override def toString(): String = {
        values.toString()
    }
}
