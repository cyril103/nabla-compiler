class ArrayIntSpan(prefixValues: ArrayInt, suffixValues: ArrayInt) {
    def prefix(): ArrayInt = {
        prefixValues
    }

    def suffix(): ArrayInt = {
        suffixValues
    }
}

class ArrayIntPartition(matchingValues: ArrayInt, nonMatchingValues: ArrayInt) {
    def matching(): ArrayInt = {
        matchingValues
    }

    def nonMatching(): ArrayInt = {
        nonMatchingValues
    }
}

class ArrayIntWithIndex(values: ArrayInt, indexes: ArrayInt) {
    def size(): Int = {
        values.length()
    }

    def value(index: Int): Int = {
        values.get(index)
    }

    def index(index: Int): Int = {
        indexes.get(index)
    }

    def valuesArray(): ArrayInt = {
        values
    }

    def indexArray(): ArrayInt = {
        indexes
    }
}

class ArrayIntNested(values: IntArray, boundaries: IntArray) {
    def rowCount(): Int = {
        val count = boundaries.length() - 1
        if count < 0 {
            0
        } else {
            count
        }
    }

    def isEmpty(): Bool = {
        this.rowCount() == 0
    }

    def isNonEmpty(): Bool = {
        this.rowCount() != 0
    }

    def row(index: Int): ArrayInt = {
        new ArrayInt(intArraySlice(values, boundaries.get(index), boundaries.get(index + 1)))
    }

    def rowArray(index: Int): IntArray = {
        intArraySlice(values, boundaries.get(index), boundaries.get(index + 1))
    }

    def flatten(): ArrayInt = {
        new ArrayInt(values)
    }

    def rowSize(index: Int): Int = {
        boundaries.get(index + 1) - boundaries.get(index)
    }

    def mapRows(transform: (ArrayInt) => ArrayInt): ArrayIntNested = {
        val rowCount = this.rowCount()
        if rowCount == 0 {
            intArrayNested(values, new IntArray(1))
        } else {
            var index = 0
            var flattenResult = new IntArray(0)
            val transformedBoundaries = new IntArray(rowCount + 1)
            transformedBoundaries.set(0, 0)
            while (index < rowCount) {
                val transformedRow = transform(this.row(index))
                flattenResult = intArrayConcat(flattenResult, transformedRow.raw())
                transformedBoundaries.set(index + 1, flattenResult.length())
                index = index + 1
            }
            intArrayNested(flattenResult, transformedBoundaries)
        }
    }
}

