        intArrayZipWithIndex(values)
    }

    def grouped(groupSize: Int): ArrayIntNested = {
        intArrayGrouped(values, groupSize)
    }

    def fold(initial: Int, combine: (Int, Int) => Int): Int = {
        arrayBaseFold[Int, Int, IntArray](values, intArrayLength, intArrayGet, initial, combine)
    }

