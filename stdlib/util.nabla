class RandomState(seedValue: Int) {
    def seed(): Int = {
        seedValue
    }
}

class RandomIntResult(valueValue: Int, stateValue: RandomState) {
    def value(): Int = {
        valueValue
    }

    def state(): RandomState = {
        stateValue
    }
}

class RandomBoolResult(valueValue: Bool, stateValue: RandomState) {
    def value(): Bool = {
        valueValue
    }

    def state(): RandomState = {
        stateValue
    }
}

class RandomChoiceResult[T](valueValue: T, stateValue: RandomState) {
    def value(): T = {
        valueValue
    }

    def state(): RandomState = {
        stateValue
    }
}

def randomStep(seed: Int): Int = {
    val mixed = (seed * 1103515245 + 12345) % 2147483647
    if mixed < 0 {
        mixed + 2147483647
    } else {
        mixed
    }
}

def randomSeed(seed: Int): RandomState = {
    new RandomState(seed)
}

def randomSeedNow(): RandomState = {
    randomSeed(timeSeed())
}

def randomSeedTime(): RandomState = {
    randomSeedNow()
}

def randomInt(state: RandomState): RandomIntResult = {
    val nextSeed = randomStep(state.seed())
    new RandomIntResult(nextSeed, new RandomState(nextSeed))
}

def randomIntInRange(state: RandomState, minimum: Int, maximum: Int): RandomIntResult = {
    randomIntRange(state, minimum, maximum)
}

def randomIntRange(state: RandomState, minimum: Int, maximum: Int): RandomIntResult = {
    val lower = if maximum < minimum {
        maximum
    } else {
        minimum
    }
    val upper = if maximum < minimum {
        minimum
    } else {
        maximum
    }
    val generated = randomInt(state)
    val rangeSize = upper - lower + 1
    if rangeSize <= 0 {
        new RandomIntResult(lower, generated.state())
    } else {
        val offset = generated.value() % rangeSize
        new RandomIntResult(lower + offset, generated.state())
    }
}

def randomBool(state: RandomState): RandomBoolResult = {
    val generated = randomInt(state)
    new RandomBoolResult(generated.value() % 2 == 0, generated.state())
}
